{
  "_comment": "零股 / 定期定額『觀察候選』篩選與評分規則。本檔只做觀察條件設定，不產生任何買賣指令。",

  "candidate_filters": {
    "rsi_max": 70,
    "max_distance_from_ma20_pct": 5.0,
    "max_distance_from_ma50_pct": 8.0,
    "max_volume_spike_ratio": 2.5
  },

  "scoring": {
    "near_ma20_bonus": 2,
    "near_ma50_bonus": 1,
    "rsi_healthy_bonus": 1,
    "rsi_oversold_bonus": 2,
    "volume_stable_bonus": 1,
    "etf_priority_bonus": 2,
    "institution_buying_bonus": 1,
    "dividend_yield_bonus": 1,
    "dividend_yield_threshold": 3.0
  },

  "penalties": {
    "vix_threshold": 25,
    "vix_penalty": 2,
    "dxy_surge_pct": 0.5,
    "dxy_penalty": 1,
    "institution_sell_days": 3,
    "institution_sell_penalty": 2,
    "rsi_overheated": 70,
    "pe_high": 40
  },

  "rules": {
    "etf_priority": true,
    "advice_mode": "observation_only",
    "min_candidate_score": 3,
    "no_day_trading": true,
    "no_chasing": true
  },

  "fundamental": {
    "value": {
      "pe_cheap": 15, "pe_fair": 25, "pb_cheap": 2.0,
      "dividend_yield_good": 4.0, "peg_good": 1.5
    },
    "growth": {
      "eps_growth_good": 15, "eps_growth_strong": 30,
      "revenue_yoy_good": 10, "revenue_yoy_strong": 20,
      "target_upside_good": 15
    }
  },

  "scoring_mode": "balanced_mode",
  "scoring_weights": {
    "growth": 1.2,
    "value": 1.0,
    "technical": 0.5,
    "risk": 1.0,
    "dividend": 0.8
  },
  "modes": {
    "value_mode": {
      "growth": 0.8,
      "value": 1.5,
      "technical": 0.4,
      "risk": 1.0,
      "dividend": 1.0
    },
    "growth_mode": {
      "growth": 1.5,
      "value": 0.8,
      "technical": 0.5,
      "risk": 1.0,
      "dividend": 0.5
    },
    "balanced_mode": {
      "growth": 1.2,
      "value": 1.0,
      "technical": 0.5,
      "risk": 1.0,
      "dividend": 0.8
    },
    "defensive_mode": {
      "growth": 0.6,
      "value": 1.3,
      "technical": 0.4,
      "risk": 1.3,
      "dividend": 1.5
    }
  },

  "_regime_comment": "每日先判斷市場狀態 (market_regime)，再依此表動態選擇基本面傾向 (value/growth/defensive)；不固定使用單一模式。",
  "regime_mode_map": {
    "Risk-On": "growth_mode",
    "Neutral": "balanced_mode",
    "Risk-Off": "defensive_mode"
  },

  "_recommendation_comment": "由上而下推薦評分：先看大盤與產業，再看基本面，技術與新聞為輔。技術面僅 10%，避免單一熱門股短線上漲就被拉高分數；過熱/追高個股直接排除。",
  "recommendation_weights": {
    "market": 0.40,
    "industry": 0.25,
    "fundamental": 0.20,
    "technical": 0.10,
    "news": 0.05
  },

  "notes": [
    "RSI 低於 70 才能列入候選",
    "價格距離 20MA 不超過 5%",
    "價格距離 50MA 不超過 8%",
    "成交量未爆大量 (量能 < 2.5 倍均量) 才算溫和",
    "VIX 高於 25 時降低進場評分",
    "DXY 單日急升 (>= 0.5%) 時降低美股評分",
    "台股法人連賣 3 天降低評分並列入觀察",
    "本益比過高 (>= 40) 的個股列入不適合追價",
    "ETF 優先於個股",
    "只給觀察，不給買賣建議"
  ]
}
